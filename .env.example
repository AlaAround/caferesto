# Database
DATABASE_URL=postgresql://tableorder:tableorder@localhost:5432/tableorder

# Redis (Upstash: copy ONLY the URL from the dashboard, not the redis-cli command)
# Example: rediss://default:YOUR_TOKEN@your-db.upstash.io:6379
REDIS_URL=redis://localhost:6379

# JWT signing (generate with: openssl genrsa -out private.pem 2048)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_EXPIRY_MINUTES=5

# Security
PROXIMITY_RADIUS_METERS=100
# Set to true to skip proximity checks during local development
DEV_SKIP_PROXIMITY=false
PATTERN_MONITOR_INTERVAL_MS=30000

# Server
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173
PUBLIC_APP_URL=http://localhost:5173
VITE_DEV_MOCK_GPS=true
# Dev: always use mock GPS (skips real GPS entirely) — use with coords matching your venue
VITE_DEV_FORCE_MOCK_GPS=false
VITE_DEV_MOCK_LAT=36.8065
VITE_DEV_MOCK_LON=10.1815

# Stripe (optional for now)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cloudinary (optional for now)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
